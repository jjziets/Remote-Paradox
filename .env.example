# Remote Paradox — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# WiFi
WIFI_SSID=YourWiFiSSID
WIFI_PSK=YourWiFiPassword
WIFI_COUNTRY=ZA

# Pi credentials
PI_HOSTNAME=remote-paradox
PI_USERNAME=home
PI_PASSWORD=changeme

# Paradox Alarm
ALARM_CODE=0000
PANEL_PC_PASSWORD=0000

# Paradox Bridge API
PARADOX_ADMIN_USER=admin
PARADOX_ADMIN_PASS=changeme
API_PORT=8080

# Pi network
PI_IP=192.168.50.32
